---
const faqs = [
  { q: 'Do FFL holders have to keep acquisition and disposition records?', a: 'Yes. Federal law requires licensed firearms dealers to maintain acquisition and disposition records under 27 CFR 478.125.' },
  { q: 'What does 27 CFR 478.125 require?', a: 'Dealers must record, for each firearm acquired and disposed of, the date, name and address of the person, and firearm/serial details in a bound format. This log book is pre-formatted to that layout.' },
  { q: 'Is this book "ATF approved"?', a: 'No log book is individually "approved" by ATF. This book is formatted to match the record layout inspectors look for under 27 CFR 478.125. A compliance tool, not legal advice.' },
  { q: 'Paperback or Hardcover — which should I get?', a: 'Paperback ($13.99) is the everyday write-in log. Hardcover ($20.99) is the durable, archival option — and the best value for a permanent record. Many dealers keep a hardcover master and a paperback working copy.' },
  { q: 'How many pages is the book?', a: '120 pages, pre-formatted for acquisition and disposition entries with space for dates, names, addresses, and serial numbers.' },
];
const amazon = 'https://www.amazon.com/dp/B0H6V4X481';
---

<section id="faq" class="bg-neutral-300">
  <div class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full">
    <div class="grid gap-10 md:grid-cols-5">
      <div class="md:col-span-2">
        <div class="max-w-xs">
          <p class="text-xs font-bold uppercase tracking-wider text-orange-600">FAQ</p>
          <h2 class="mt-2 text-2xl font-bold tracking-tight text-neutral-900 md:text-3xl font-serif">Frequently Asked</h2>
        </div>
      </div>
      <div class="md:col-span-3">
        <div class="divide-y divide-neutral-200">
          {faqs.map((f) => (
            <details class="group py-4" name="faq">
              <summary class="flex w-full cursor-pointer list-none items-center justify-between gap-3 font-semibold text-neutral-900">
                {f.q}
                <svg class="h-5 w-5 shrink-0 text-orange-600 transition-transform duration-300 group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
              </summary>
              <p class="pb-1 pt-3 text-sm text-neutral-600">{f.a}</p>
            </details>
          ))}
        </div>
        <a href={amazon} target="_blank" rel="noopener" class="mt-6 inline-flex items-center justify-center rounded-xl bg-orange-500 px-7 py-3.5 font-extrabold text-white shadow-lg shadow-orange-500/25 transition hover:bg-orange-600">Get the Paperback — $13.99</a>
      </div>
    </div>
  </div>
</section>
