---
const pb = 'https://www.amazon.com/dp/B0H6V4X481';
const hc = 'https://www.amazon.com/dp/B0H6VSF6S6';
const pbImg = 'https://images-na.ssl-images-amazon.com/images/P/B0H6V4X481.01.LZZZZZZZ.jpg';
const hcImg = 'https://images-na.ssl-images-amazon.com/images/P/B0H6VSF6S6.01.LZZZZZZZ.jpg';
---

<section class="bg-neutral-300/50 overflow-hidden">
  <div class="mx-auto grid max-w-[85rem] gap-4 px-4 py-14 sm:px-6 md:grid-cols-2 md:items-center md:gap-8 lg:px-8 2xl:max-w-full">
    <div>
      <span class="inline-flex items-center gap-1.5 rounded-full border border-orange-200 bg-orange-100 px-3 py-1.5 text-xs font-bold uppercase tracking-wider text-orange-700">27 CFR § 478.125 Compliant</span>
      <h1 class="mt-4 block text-3xl font-bold tracking-tight text-balance text-neutral-900 sm:text-4xl lg:text-6xl lg:leading-tight font-serif">
        The ATF Walks In.<br />Your <span class="text-orange-600">Bound Book</span> Better Be Ready.
      </h1>
      <p class="mt-3 text-lg leading-relaxed text-pretty text-neutral-600 lg:w-4/5">
        The FFL Acquisition &amp; Disposition Book — a pre-formatted, ATF-compliant A&amp;D log ledger built for dealers, gunsmiths &amp; manufacturers who don't gamble with their license.
      </p>
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-green-500/30 bg-green-500/10 px-3 py-1.5 text-sm font-semibold text-green-600">
        <span class="h-2 w-2 rounded-full bg-green-500"></span> In Stock — ships from Amazon
      </div>

      <div class="mt-7 grid w-full gap-3 sm:inline-flex">
        <a class="inline-flex items-center justify-center rounded-xl bg-orange-500 px-6 py-3.5 font-extrabold text-white shadow-lg shadow-orange-500/25 transition hover:bg-orange-600" href={pb} target="_blank" rel="noopener">Buy Paperback — $13.99</a>
        <a class="inline-flex items-center justify-center rounded-xl border-2 border-orange-500 px-6 py-3.5 font-extrabold text-orange-700 transition hover:bg-orange-50" href={hc} target="_blank" rel="noopener">Buy Hardcover — $20.99</a>
      </div>
    </div>

    <div class="mx-auto flex w-full max-w-[92%] items-stretch justify-center gap-1 px-0">
      <div class="w-2/5 rounded-2xl border border-neutral-300 bg-neutral-100 p-1 shadow-2xl shadow-neutral-900/10 transition duration-300 hover:-translate-y-1">
        <img src={pbImg} alt="FFL Acquisition and Disposition Book — Paperback" style="width:100%;max-width:100%;display:block" class="rounded-lg shadow-md" loading="eager" />
        <p class="mt-2 text-center text-xs font-semibold text-neutral-500">Paperback · 120 pp</p>
      </div>
      <div class="w-2/5 rounded-2xl border border-neutral-300 bg-neutral-100 p-1 shadow-2xl shadow-neutral-900/10 transition duration-300 hover:-translate-y-1">
        <img src={hcImg} alt="FFL Acquisition and Disposition Book — Hardcover" style="width:100%;max-width:100%;display:block" class="rounded-lg shadow-md" loading="eager" />
        <p class="mt-2 text-center text-xs font-semibold text-neutral-500">Hardcover · archive</p>
      </div>
    </div>
  </div>
</section>
