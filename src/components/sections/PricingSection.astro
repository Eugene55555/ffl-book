---
const pb = 'https://www.amazon.com/dp/B0H6V4X481';
const hc = 'https://www.amazon.com/dp/B0H6VSF6S6';
const starter = {
  name: 'Paperback', desc: 'Working copy', price: '$13.99',
  features: ['120 pre-formatted pages','Write-in, lay-flat use','Perfect for daily logging'], cta: 'Buy Paperback $13.99', url: pb,
};
const pro = {
  name: 'Hardcover', desc: 'Archive grade', badge: 'Best value', price: '$20.99',
  features: ['Same 120-page layout','Durable, long-life binding','Ideal permanent record'], cta: 'Buy Hardcover $20.99', url: hc,
};
---

<section id="formats" class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full">
  <div class="mx-auto mb-10 max-w-2xl text-center">
    <p class="text-xs font-bold uppercase tracking-wider text-orange-600">Choose Your Format</p>
    <h2 class="mt-2 text-2xl font-bold tracking-tight text-neutral-900 md:text-3xl font-serif">Paperback or Hardcover — Same Compliance</h2>
    <p class="mt-2 text-neutral-600">Both are the same ATF-compliant log. Pick the one that fits how you keep records.</p>
  </div>

  <div class="flex flex-wrap items-stretch justify-center gap-4 sm:gap-0">
    <div class="w-full rounded-2xl border border-neutral-300 bg-neutral-100 p-6 sm:w-1/2 sm:p-8 lg:w-1/3">
      <h3 class="text-2xl font-bold text-neutral-900">{starter.name}</h3>
      <p class="text-neutral-500">{starter.desc}</p>
      <div class="mb-4 mt-2"><span class="text-4xl font-bold text-neutral-900">{starter.price}</span></div>
      <ul class="mb-6 space-y-2 text-neutral-600">
        {starter.features.map((f) => (
          <li class="flex items-center gap-2"><span class="flex h-5 w-5 items-center justify-center rounded-full bg-orange-500 text-white"><svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 6l3 3 5-6"/></svg></span>{f}</li>
        ))}
      </ul>
      <a href={starter.url} target="_blank" rel="noopener" class="block rounded-xl bg-neutral-700 px-8 py-3 text-center text-sm font-bold text-white transition hover:bg-neutral-800">{starter.cta}</a>
    </div>

    <div class="relative w-full rounded-2xl bg-gradient-to-tr from-[#FF512F] to-[#F09819] p-6 shadow-2xl sm:w-1/2 sm:p-8 lg:w-1/3">
      <span class="absolute -top-3 left-8 inline-block rounded-full bg-neutral-100/70 px-3 py-1 text-center text-xs font-bold uppercase tracking-wider text-orange-700">{pro.badge}</span>
      <h3 class="text-2xl font-bold text-white">{pro.name}</h3>
      <p class="text-orange-100">{pro.desc}</p>
      <div class="mb-4 mt-2"><span class="text-4xl font-bold text-white">{pro.price}</span></div>
      <ul class="mb-6 space-y-2 text-orange-100">
        {pro.features.map((f) => (
          <li class="flex items-center gap-2"><span class="flex h-5 w-5 items-center justify-center rounded-full bg-neutral-100/30"><svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 6l3 3 5-6"/></svg></span>{f}</li>
        ))}
      </ul>
      <a href={pro.url} target="_blank" rel="noopener" class="block rounded-xl bg-neutral-100 px-8 py-3 text-center text-sm font-bold text-orange-700 transition hover:bg-orange-50">{pro.cta}</a>
    </div>
  </div>
</section>
