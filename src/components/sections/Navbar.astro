---
const amazon = 'https://www.amazon.com/dp/B0H6V4X481';
const links = [
  { href: '#why', label: 'Why' },
  { href: '#inside', label: 'Inside' },
  { href: '#formats', label: 'Formats' },
  { href: '#faq', label: 'FAQ' },
];
---

<header id="site-header" style="position:fixed;top:0;left:0;right:0" class="z-50 flex flex-col">
  <nav class="mx-auto mt-3 flex w-[94%] max-w-[85rem] items-center justify-between gap-3 rounded-[36px] border border-neutral-300 bg-neutral-100/90 px-4 py-2.5 backdrop-blur-xl sm:px-6 lg:px-8">
    <a class="flex-none rounded-xl text-xl font-bold text-neutral-900" href="#top">
      <span class="inline-flex items-center gap-2">
        <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-orange-500 text-sm font-extrabold text-white">FFL</span>
        Bound Book
      </span>
    </a>

    <div class="hidden items-center gap-6 md:flex">
      {links.map((l) => (
        <a class="font-medium text-neutral-700 transition hover:text-orange-600" href={l.href}>{l.label}</a>
      ))}
      <a class="inline-flex items-center gap-2 rounded-full bg-orange-500 px-5 py-2.5 font-bold text-white shadow-lg shadow-orange-500/25 transition hover:bg-orange-600" href={amazon} target="_blank" rel="noopener">Buy $13.99</a>
    </div>

    <button id="burger-btn" type="button" class="inline-flex items-center justify-center rounded-lg border border-neutral-300 bg-neutral-100 p-2 text-neutral-700 transition hover:bg-neutral-200 md:hidden" aria-controls="mobile-menu" aria-label="Toggle navigation" aria-expanded="false">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    </button>
  </nav>

  <div id="mobile-menu" class="mx-auto mt-1 flex w-[94%] max-w-[85rem] flex-col gap-1 overflow-hidden rounded-2xl border border-neutral-300 bg-neutral-100 p-0 shadow-lg transition-all duration-300 md:hidden" style="max-height:0">
    {links.map((l) => (
      <a class="rounded-lg px-3 py-2.5 text-neutral-800 transition hover:bg-white hover:text-orange-600" href={l.href}>{l.label}</a>
    ))}
    <a class="mt-1 rounded-xl bg-orange-500 px-4 py-3 text-center font-bold text-white transition hover:bg-orange-600" href={amazon} target="_blank" rel="noopener">Buy on Amazon — $13.99</a>
  </div>
</header>

<script is:inline>
  const btn = document.getElementById('burger-btn');
  const menu = document.getElementById('mobile-menu');
  function toggle() {
    const open = menu.style.maxHeight && menu.style.maxHeight !== '0px';
    if (open) {
      menu.style.maxHeight = '0px';
      btn.setAttribute('aria-expanded', 'false');
    } else {
      menu.style.maxHeight = '500px';
      btn.setAttribute('aria-expanded', 'true');
    }
  }
  btn?.addEventListener('click', (e) => { e.stopPropagation(); toggle(); });
  document.addEventListener('click', (e) => {
    if (menu.style.maxHeight && menu.style.maxHeight !== '0px' && !menu.contains(e.target) && e.target !== btn) {
      menu.style.maxHeight = '0px';
      btn.setAttribute('aria-expanded', 'false');
    }
  });
  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => { menu.style.maxHeight = '0px'; btn.setAttribute('aria-expanded', 'false'); }));
</script>
