---
const items = [
  { ic: '⇄', t: 'A&D columns, done right', d: 'Acquisition and disposition laid out side by side, exactly the way records are expected to read.' },
  { ic: '#', t: 'Date · Name · Address · Serial', d: 'Dedicated fields for every required data point — no guessing what goes where.' },
  { ic: '▣', t: 'Bound, not loose-leaf', d: 'A proper bound book format — the kind inspectors expect to see, not a ring binder.' },
  { ic: '▤', t: '120 pages of logs', d: 'Enough room for a real volume of business without running out mid-year.' },
  { ic: '✎', t: 'Notes space per entry', d: 'A line for context on every transaction — transfers, returns, corrections, anything.' },
  { ic: '◧', t: 'Two formats', d: 'Paperback for the counter, hardcover for the permanent file. Same book, your call.' },
];
---

<section id="inside" class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full">
  <div class="mb-10 max-w-2xl">
    <p class="text-xs font-bold uppercase tracking-wider text-orange-600">Built In</p>
    <h2 class="mt-2 text-2xl font-bold tracking-tight text-neutral-900 md:text-3xl font-serif">Every Field an Inspector Looks For</h2>
    <p class="mt-2 text-neutral-600">Pre-formatted acquisition &amp; disposition columns — just write it down, the structure is already correct.</p>
  </div>
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {items.map((c) => (
      <div class="rounded-2xl border border-neutral-200 bg-white p-6 transition duration-300 hover:-translate-y-1 hover:shadow-xl">
        <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-orange-100 text-lg font-bold text-orange-600">{c.ic}</div>
        <h3 class="text-base font-bold text-neutral-900">{c.t}</h3>
        <p class="mt-2 text-sm text-neutral-600">{c.d}</p>
      </div>
    ))}
  </div>

  <blockquote class="mt-10 rounded-r-xl border-l-4 border-orange-500 bg-orange-50 p-5 font-serif text-lg leading-relaxed text-neutral-800 lg:text-xl">
    "Each licensee shall record the receipt and disposition of each firearm... in a bound record... with the date of receipt, the name and address of the person, the firearm's serial number, and the disposition information." <span class="font-bold text-orange-600">— 27 CFR § 478.125</span>
  </blockquote>

  <div class="mt-6 flex gap-3 rounded-xl border border-orange-300 bg-orange-50 p-4">
    <span class="text-xl">⚠</span>
    <p class="text-sm text-orange-800">Compliance note: no log book is individually "approved" by ATF. This book is formatted to match the record layout inspectors look for under 27 CFR 478.125. It is a compliance tool, not legal advice — verify current text at eCFR.gov.</p>
  </div>
</section>
