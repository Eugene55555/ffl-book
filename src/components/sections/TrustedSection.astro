---
const badges = ['FFL Dealers','Gunsmiths','Manufacturers','Range Shops','Collectors with FFL','Pawn & Gun'];
---

<section id="why" class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full">
  <div class="mb-8 max-w-2xl">
    <p class="text-xs font-bold uppercase tracking-wider text-orange-600">Trusted by</p>
    <h2 class="mt-2 text-2xl font-bold tracking-tight text-neutral-900 md:text-3xl font-serif">Chosen by FFL Holders Who Don't Gamble</h2>
    <p class="mt-2 text-neutral-600">From single-location gunsmiths to high-volume dealers — the same compliance problem, the same simple answer.</p>
  </div>
  <div class="flex flex-wrap gap-3">
    {badges.map((b) => (
      <span class="rounded-full border border-neutral-300 bg-neutral-100 px-4 py-2.5 text-sm font-semibold text-neutral-600 transition hover:border-orange-500 hover:bg-neutral-100 hover:text-orange-600">{b}</span>
    ))}
  </div>
</section>
