---
import Layout from '../layouts/Layout.astro';

const variants = [
  {
    slug: 'ffl',
    title: 'FFL Bound Book',
    desc: 'ATF-compliant FFL Acquisition & Disposition log — screwfast-style (orange primary, oklch palette).',
    tag: 'live',
    href: '/ffl/',
  },
  {
    slug: 'v2',
    title: 'Variant B — coming soon',
    desc: 'A second design direction. Create a copy of /ffl/ and restyle it to publish a new variant here.',
    tag: 'soon',
    href: '#',
  },
];
---

<Layout title="KDP Book Sites — design variants hub">
  <main id="top" class="mx-auto max-w-[85rem] px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-10 max-w-2xl">
      <p class="text-xs font-bold uppercase tracking-wider text-orange-600">Book Landing Sites</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 md:text-4xl font-serif">Pick a design variant</h1>
      <p class="mt-2 text-neutral-600">Each book gets its own page; each design direction is its own folder in the same repo (Astro + Tailwind v4 + Preline). Add a variant by copying a folder and restyling it.</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {variants.map((v) => (
        <a href={v.href} class={`group relative flex flex-col rounded-2xl border border-neutral-200 bg-white p-6 transition duration-300 hover:-translate-y-1 hover:shadow-xl ${v.tag === 'soon' ? 'pointer-events-none opacity-60' : ''}`}>
          <span class={`absolute right-4 top-4 rounded-full px-2.5 py-1 text-xs font-bold uppercase ${v.tag === 'live' ? 'bg-green-500/10 text-green-600' : 'bg-neutral-100 text-neutral-500'}`}>{v.tag}</span>
          <h2 class="text-lg font-bold text-neutral-900">{v.title}</h2>
          <p class="mt-2 flex-1 text-sm text-neutral-600">{v.desc}</p>
          {v.tag === 'live' && <span class="mt-4 inline-flex items-center gap-1 font-semibold text-orange-600">Open →</span>}
        </a>
      ))}
    </div>
  </main>
</Layout>
